---
import fs from 'fs';
import path from 'path';
import '../reset.css';
import '../styles.css';

const contentPath = path.join(process.cwd(), 'public/content/home.json');
const content = JSON.parse(fs.readFileSync(contentPath, 'utf-8'));

const { site_info, hero, attorney, about, services, why_us, contact, footer, mascot } = content;
---

<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={site_info.description}>
    <title>{site_info.title}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        burgundy: {
                            dark: '#3d1f1f',
                            DEFAULT: '#5c2e2e',
                            light: '#7a3e3e',
                        },
                        sienna: {
                            DEFAULT: '#a0522d',
                            light: '#c07854',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body>
<!-- Navigation -->
<nav class="navbar">
    <div class="container">
        <div class="nav-content">
            <div class="logo">
                <span class="logo-icon">⚖</span>
                <span class="logo-text">CA Gurev Dorina</span>
            </div>
            <input type="checkbox" id="menu-toggle" class="menu-toggle">
            <label for="menu-toggle" class="mobile-menu-toggle">
                <span></span>
                <span></span>
                <span></span>
            </label>
            <div class="nav-links">
                <nav class="nav-menu">
                    <a href="#about" class="nav-link">Despre</a>
                    <a href="#services" class="nav-link">Servicii</a>
                    <a href="#why-us" class="nav-link">De ce noi</a>
                    <a href="#contact" class="nav-link">Contact</a>
                </nav>
                <div class="mobile-menu-actions">
                    <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Consultație+Juridică&details=Cabinet+Avocat+Gurev+Dorina&location=str.+Academician+Sergiu+Rădăuțan,+9,+Chișinău" target="_blank" class="mobile-menu-btn">
                        <span class="menu-btn-icon">📅</span>
                        <span class="menu-btn-text">Adaugă la Calendar</span>
                    </a>
                    <a href="https://maps.google.com/?q=str.+Academician+Sergiu+Rădăuțan,+9,+Chișinău,+Moldova" target="_blank" class="mobile-menu-btn">
                        <span class="menu-btn-icon">📍</span>
                        <span class="menu-btn-text">Deschide în Hărți</span>
                    </a>
                    <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="mobile-menu-btn">
                        <span class="menu-btn-icon">📞</span>
                        <span class="menu-btn-text">Apel Urgent</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="hero">
    <div class="hero-background"></div>
    <div class="container">
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="hero-title">
                    <span class="title-line">{hero.title_line1}</span>
                    <span class="title-line">{hero.title_line2}</span>
                </h1>
                <p class="hero-description">{hero.description}</p>
                <div class="hero-cta">
                    <a href="#contact" class="btn btn-primary">{hero.primary_button}</a>
                    <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="btn btn-secondary">{hero.secondary_button}</a>
                </div>
            </div>
            <div class="attorney-card">
                <div class="attorney-badge">
                    <span class="badge-icon">⚖</span>
                    <span class="badge-text">Avocat Licențiat</span>
                </div>
                <h2 class="attorney-name">{attorney.name}</h2>
                <p class="attorney-title">{attorney.title}</p>
                <div class="attorney-credentials">
                    <div class="credential-item">
                        <span class="credential-label">Licență</span>
                        <span class="credential-value">{attorney.license_number}</span>
                    </div>
                    <div class="credential-item">
                        <span class="credential-label">Barou</span>
                        <span class="credential-value">{attorney.bar}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="about">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">{about.tag}</span>
            <h2 class="section-title">{about.title}</h2>
        </div>
        <div class="about-content">
            <div class="about-text">
                <p class="about-description">{about.paragraph1}</p>
                <p class="about-description">{about.paragraph2}</p>
                <div class="about-highlights">
                    {about.stats.map((stat: { number: string; label: string }) => (
                            <div class="highlight-item">
                                <span class="highlight-number">{stat.number}</span>
                                <span class="highlight-label">{stat.label}</span>
                            </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="services">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">{services.tag}</span>
            <h2 class="section-title">{services.title}</h2>
        </div>
        <div class="services-grid">
            {services.items.map((service: { title: string; description: string }) => (
                    <div class="service-card">
                        <h3 class="service-title">{service.title}</h3>
                        <p class="service-description">{service.description}</p>
                    </div>
            ))}
        </div>
    </div>
</section>

<!-- Why Us Section -->
<section id="why-us" class="why-us">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">{why_us.tag}</span>
            <h2 class="section-title">{why_us.title}</h2>
        </div>
        <div class="features-grid">
            {why_us.features.map((feature: { number: string; title: string; description: string }) => (
                    <div class="feature-item">
                        <div class="feature-number">{feature.number}</div>
                        <h3 class="feature-title">{feature.title}</h3>
                        <p class="feature-description">{feature.description}</p>
                    </div>
            ))}
        </div>
    </div>
</section>

<!-- Contact Section -->
<section id="contact" class="contact">
    <div class="container">
        <div class="contact-content">
            <div class="contact-info">
                <span class="section-tag light">{contact.tag}</span>
                <h2 class="section-title light">{contact.title}</h2>
                <p class="contact-description">{contact.description}</p>
                <div class="contact-methods">
                    <div class="contact-method">
                        <div class="method-details">
                            <span class="method-label">Telefon Mobil</span>
                            <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="method-value">{contact.phone}</a>
                        </div>
                    </div>
                    <div class="contact-method">
                        <div class="method-details">
                            <span class="method-label">Email</span>
                            <a href={`mailto:${contact.email}`} class="method-value">{contact.email}</a>
                        </div>
                    </div>
                    <div class="contact-method">
                        <div class="method-details">
                            <span class="method-label">Adresă</span>
                            <span class="method-value" set:html={contact.address.replace(/\n/g, '<br>')}></span>
                        </div>
                    </div>
                    <div class="contact-method">
                        <div class="method-details">
                            <span class="method-label">Program</span>
                            <span class="method-value" set:html={contact.schedule.replace(/\n/g, '<br>')}></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="contact-form-wrapper">
                <form class="contact-form">
                    <div class="form-group">
                        <label for="name">Nume Complet</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="phone">Telefon</label>
                        <input type="tel" id="phone" name="phone" required>
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="subject">Subiect</label>
                        <select id="subject" name="subject" required>
                            <option value="">Selectați domeniul</option>
                            <option value="penal">Drept Penal</option>
                            <option value="juvenila">Delincvența Juvenilă</option>
                            <option value="penal-general">Drept Penal: Partea Generală</option>
                            <option value="penal-special">Drept Penal: Partea Specială</option>
                            <option value="other">Altul</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="message">Mesaj</label>
                        <textarea id="message" name="message" rows="5" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Trimite Mesajul</button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Mascot -->
<div class="mascot-container">
    <div class="mascot-message">
        {mascot.message}
    </div>
    <div class="mascot">
        <img src="/lady-justice.png" alt="Lady Justice" class="mascot-image">
    </div>
</div>

<!-- Footer -->
<footer class="footer">
    <div class="container">
        <div class="footer-content">
            <div class="footer-info">
                <div class="footer-brand">
                    <div class="footer-logo">
                        <span class="logo-icon">⚖</span>
                        <span>CA Gurev Dorina</span>
                    </div>
                    <p class="footer-description">{footer.tagline}</p>
                </div>
            </div>
            <div class="footer-contact">
                <h3 class="footer-heading">Contact</h3>
                <p>{contact.phone}</p>
                <p>{contact.email}</p>
                <h3 class="footer-heading">Licență</h3>
                <p>{attorney.license_number}</p>
                <p>{attorney.bar}</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>{footer.copyright}</p>
        </div>
    </div>
</footer>
</body>
</html>