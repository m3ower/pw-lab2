---
const title = "Cabinet Avocat Gurev Dorina | Servicii Juridice Chișinău";
---

<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Cabinet Avocat Gurev Dorina - Servicii juridice profesionale în Chișinău">
    <title>{title}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        burgundy: {
                            dark: '#3d1f1f',
                            DEFAULT: '#5c2e2e',
                            light: '#7a3e3e',
                        },
                        sienna: {
                            DEFAULT: '#a0522d',
                            light: '#c07854',
                        }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="/src/reset.css">
    <link rel="stylesheet" href="/src/styles.css">
</head>
<body>
<!-- Navigation -->
<nav class="navbar">
    <div class="container">
        <div class="nav-content">
            <div class="logo">
                <span class="logo-icon">⚖</span>
                <span class="logo-text">CA Gurev Dorina</span>
            </div>
            <input type="checkbox" id="menu-toggle" class="menu-toggle">
            <label for="menu-toggle" class="mobile-menu-toggle">
                <span></span>
                <span></span>
                <span></span>
            </label>
            <div class="nav-links">
                <nav class="nav-menu">
                    <a href="#about" class="nav-link">Despre</a>
                    <a href="#services" class="nav-link">Servicii</a>
                    <a href="#why-us" class="nav-link">De ce noi</a>
                    <a href="#contact" class="nav-link">Contact</a>
                </nav>
                <div class="mobile-menu-actions">
                    <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Consultație+Juridică&details=Cabinet+Avocat+Gurev+Dorina&location=str.+Academician+Sergiu+Rădăuțan,+9,+Chișinău" target="_blank" class="mobile-menu-btn">
                        <span class="menu-btn-icon">📅</span>
                        <span class="menu-btn-text">Adaugă la Calendar</span>
                    </a>
                    <a href="https://maps.google.com/?q=str.+Academician+Sergiu+Rădăuțan,+9,+Chișinău,+Moldova" target="_blank" class="mobile-menu-btn">
                        <span class="menu-btn-icon">📍</span>
                        <span class="menu-btn-text">Deschide în Hărți</span>
                    </a>
                    <a href="tel:+37369257335" class="mobile-menu-btn">
                        <span class="menu-btn-icon">📞</span>
                        <span class="menu-btn-text">Apel Urgent</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="hero">
    <div class="hero-background"></div>
    <div class="container">
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="hero-title">
                    <span class="title-line">Protecție Juridică</span>
                    <span class="title-line">de Încredere</span>
                </h1>
                <p class="hero-description">
                    Reprezentare profesională și consultanță juridică cu experiență în Chișinău.
                    Soluții personalizate pentru nevoile dumneavoastră legale.
                </p>
                <div class="hero-cta">
                    <a href="#contact" class="btn btn-primary">Programează o Consultație</a>
                    <a href="tel:+37369257335" class="btn btn-secondary">Sună Acum</a>
                </div>
            </div>
            <div class="attorney-card">
                <div class="attorney-badge">
                    <span class="badge-icon">⚖</span>
                    <span class="badge-text">Avocat Licențiat</span>
                </div>
                <h2 class="attorney-name">Gurev Dorina</h2>
                <p class="attorney-title">Doctor în Drept</p>
                <div class="attorney-credentials">
                    <div class="credential-item">
                        <span class="credential-label">Licență</span>
                        <span class="credential-value">Nr. 3179 / 11 August 2017</span>
                    </div>
                    <div class="credential-item">
                        <span class="credential-label">Barou</span>
                        <span class="credential-value">Baroul Chișinău</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="about">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Despre Cabinet</span>
            <h2 class="section-title">Experiență și Profesionalism</h2>
        </div>
        <div class="about-content">
            <div class="about-text">
                <p class="about-description">
                    Cabinet Avocat Gurev Dorina oferă servicii juridice complete pentru persoane fizice și juridice în Chișinău și pe întreg teritoriul Republicii Moldova. Cu o experiență solidă în practică juridică și o înțelegere profundă a legislației moldovenești, oferim soluții personalizate pentru fiecare client.
                </p>
                <p class="about-description">
                    Abordarea noastră se bazează pe comunicare transparentă, dedicare completă fiecărui caz și utilizarea celor mai bune strategii juridice pentru a proteja drepturile și interesele clienților noștri.
                </p>
                <div class="about-highlights">
                    <div class="highlight-item">
                        <span class="highlight-number">10+</span>
                        <span class="highlight-label">Ani Experiență</span>
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-number">500+</span>
                        <span class="highlight-label">Cazuri Rezolvate</span>
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-number">95%</span>
                        <span class="highlight-label">Rate de Succes</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="services">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Servicii</span>
            <h2 class="section-title">Domenii de Practică</h2>
        </div>
        <div class="services-grid">
            <div class="service-card">
                <h3 class="service-title">Drept Penal</h3>
                <p class="service-description">Apărare în cauze penale, reprezentare în toate etapele procesului penal</p>
            </div>
            <div class="service-card">
                <h3 class="service-title">Delincvența Juvenilă</h3>
                <p class="service-description">Apărarea minorilor în conflict cu legea, protecția drepturilor copiilor</p>
            </div>
            <div class="service-card">
                <h3 class="service-title">Drept Penal: Partea Generală</h3>
                <p class="service-description">Consultanță și reprezentare în aspecte generale ale dreptului penal</p>
            </div>
            <div class="service-card">
                <h3 class="service-title">Drept Penal: Partea Specială</h3>
                <p class="service-description">Specializare în infracțiuni specifice și cazuri complexe de drept penal</p>
            </div>
        </div>
    </div>
</section>

<!-- Why Us Section -->
<section id="why-us" class="why-us">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Avantaje</span>
            <h2 class="section-title">De Ce Să Ne Alegeți</h2>
        </div>
        <div class="features-grid">
            <div class="feature-item">
                <div class="feature-number">01</div>
                <h3 class="feature-title">Experiență Vastă</h3>
                <p class="feature-description">
                    Peste 10 ani de practică juridică în diverse domenii, cu sute de cazuri rezolvate cu succes.
                </p>
            </div>
            <div class="feature-item">
                <div class="feature-number">02</div>
                <h3 class="feature-title">Abordare Personalizată</h3>
                <p class="feature-description">
                    Fiecare caz este tratat individual, cu strategii adaptate specific situației dumneavoastră.
                </p>
            </div>
            <div class="feature-item">
                <div class="feature-number">03</div>
                <h3 class="feature-title">Comunicare Transparentă</h3>
                <p class="feature-description">
                    Veți fi informat constant despre progresul cazului dumneavoastră, fără costuri ascunse.
                </p>
            </div>
            <div class="feature-item">
                <div class="feature-number">04</div>
                <h3 class="feature-title">Disponibilitate</h3>
                <p class="feature-description">
                    Programări flexibile, inclusiv în afara programului standard, pentru confortul dumneavoastră.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section id="contact" class="contact">
    <div class="container">
        <div class="contact-content">
            <div class="contact-info">
                <span class="section-tag light">Contactați-ne</span>
                <h2 class="section-title light">Programează o Consultație</h2>
                <p class="contact-description">
                    Sunteți bineveniți să ne contactați pentru o consultație inițială.
                    Vă vom răspunde în cel mai scurt timp posibil.
                </p>
                <div class="contact-methods">
                    <div class="contact-method">
                        <div class="method-details">
                            <span class="method-label">Telefon Mobil</span>
                            <a href="tel:+37369257335" class="method-value">+373 692 57 335</a>
                        </div>
                    </div>
                    <div class="contact-method">
                        <div class="method-details">
                            <span class="method-label">Email</span>
                            <a href="mailto:gurev.dorina.drept@gmail.com" class="method-value">gurev.dorina.drept@gmail.com</a>
                        </div>
                    </div>
                    <div class="contact-method">
                        <div class="method-details">
                            <span class="method-label">Adresă</span>
                            <span class="method-value">str. Academician Sergiu Rădăuțan, 9 ap. 163<br>Chișinău, Moldova</span>
                        </div>
                    </div>
                    <div class="contact-method">
                        <div class="method-details">
                            <span class="method-label">Program</span>
                            <span class="method-value">Luni - Vineri: 9:00 - 18:00<br>Programări în afara programului disponibile</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="contact-form-wrapper">
                <form class="contact-form">
                    <div class="form-group">
                        <label for="name">Nume Complet</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="phone">Telefon</label>
                        <input type="tel" id="phone" name="phone" required>
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="subject">Subiect</label>
                        <select id="subject" name="subject" required>
                            <option value="">Selectați domeniul</option>
                            <option value="penal">Drept Penal</option>
                            <option value="juvenila">Delincvența Juvenilă</option>
                            <option value="penal-general">Drept Penal: Partea Generală</option>
                            <option value="penal-special">Drept Penal: Partea Specială</option>
                            <option value="other">Altul</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="message">Mesaj</label>
                        <textarea id="message" name="message" rows="5" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Trimite Mesajul</button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Mascot -->
<div class="mascot-container">
    <div class="mascot-message">
        Aveți nevoie de asistență juridică? Suntem aici pentru dumneavoastră!
    </div>
    <div class="mascot">
        <img src="/lady-justice.png" alt="Lady Justice" class="mascot-image">
    </div>
</div>

<!-- Footer -->
<footer class="footer">
    <div class="container">
        <div class="footer-content">
            <div class="footer-info">
                <div class="footer-brand">
                    <div class="footer-logo">
                        <span class="logo-icon">⚖</span>
                        <span>CA Gurev Dorina</span>
                    </div>
                    <p class="footer-description">
                        Protecție juridică profesională în Chișinău
                    </p>
                </div>
            </div>
            <div class="footer-contact">
                <h3 class="footer-heading">Contact</h3>
                <p>+373 692 57 335</p>
                <p>gurev.dorina.drept@gmail.com</p>
                <h3 class="footer-heading">Licență</h3>
                <p>Nr. 3179 / 11 August 2017</p>
                <p>Baroul Chișinău</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Cabinet Avocat Gurev Dorina. Toate drepturile rezervate.</p>
        </div>
    </div>
</footer>
</body>
</html>